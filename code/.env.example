# Default config: Claude Sonnet via Anthropic's OpenAI-compatible endpoint.
# The same code works against any OpenAI-compatible API by changing these two values.

OPENAI_API_KEY=                                          # your Anthropic API key (sk-ant-...)
OPENAI_BASE_URL=https://api.anthropic.com/v1/
OPENAI_MODEL=claude-sonnet-4-6

# --- Other provider examples (uncomment one and set OPENAI_API_KEY accordingly) ---
# OpenAI:        unset OPENAI_BASE_URL,  OPENAI_MODEL=gpt-5-mini
# Groq:          OPENAI_BASE_URL=https://api.groq.com/openai/v1
# Together:      OPENAI_BASE_URL=https://api.together.xyz/v1
# DeepSeek:      OPENAI_BASE_URL=https://api.deepseek.com/v1
# OpenRouter:    OPENAI_BASE_URL=https://openrouter.ai/api/v1
