tmp/

# Internal spec / planning version of the README — not for the public repo.
# The public-facing README.md is committed; this detailed one is for initial use 
# during series planning only.
README-INTERNAL.md

# Internal Claude Code config + operational guidance — kept locally, not shipped.
.claude/
CLAUDE.md

# (Internal build/design specs now live under tmp/spec/ — covered by the tmp/ rule above.)

# Alternative sandbox directories (scratch/experiment scripts use these)
episodes/*/_sandbox*/

# Underscore-prefixed directories under episodes/ are scratch/experiment dirs
# (e.g. _sweep_*, _what_if_*, _ablation_*, _before_*) — same convention as
# the _*.py scripts rule below but extended to directories.
episodes/_*/

# Underscore-prefixed scripts in episodes/ are internal/scratch (e.g. _before.py,
# _what_if_ep1_only.py) — used for reproducing recorded experiments, not viewer-facing.
# Negation re-includes dunder modules (__init__.py, __main__.py), which also start
# with "_" and MUST ship — without it the md2html package can't be imported.
episodes/**/_*.py
!episodes/**/__*.py

# Recorded run logs that wind up inside episodes/<N-name>/ are run byproducts.
# Canonical run logs live under tmp/runs/<epXX>/ (which is already gitignored
# via the top-level tmp/ rule).
episodes/**/run*.log

# --- Companion code artifacts (migrated from the former code/.gitignore;
# consolidated here now that the whole repo ships as one unit) ---
# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ruff_cache/
# Virtualenvs
.venv/
venv/
env/
# Environment files — .env.example IS committed; only real .env files are ignored
.env
.env.local
# Agent working dirs + per-run artifacts (recreated by agent.py / capture.py each run)
episodes/*/sandbox/
episodes/*/logs/
episodes/*/tool_calls.jsonl
logs/
# IDE / editor
.vscode/
.idea/
*.swp
