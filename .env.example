# Default config: Claude Sonnet via Anthropic's OpenAI-compatible endpoint.
# Switch providers by changing LLM_BASE_URL + LLM_AGENT_MODEL - the matching key
# below is selected automatically (see api_key_for), so you never move keys around.

LLM_BASE_URL=https://api.anthropic.com/v1/
LLM_AGENT_MODEL=claude-sonnet-4-6

# Summarizer used only for compaction (Ep 3+). Each model travels with its own
# endpoint, so they can be different providers. Leave both unset to reuse the
# agent's model+endpoint; to use a different provider, set BOTH lines.
LLM_SUMMARIZER_BASE_URL=https://api.anthropic.com/v1/
LLM_SUMMARIZER_MODEL=claude-haiku-4-5

# All episodes use the `openai` SDK against an OpenAI-compatible endpoint, so
# the default above runs Claude through Anthropic's compatible API with the key
# auto-selected. LLM_MAX_TOKENS is an optional response cap (left here for
# convenience; the agent loops don't set it).
LLM_MAX_TOKENS=4096

# --- Other provider examples (change LLM_BASE_URL; the matching key is auto-selected) ---
# OpenAI:        unset LLM_BASE_URL,  LLM_AGENT_MODEL=gpt-5-mini
# Groq:          LLM_BASE_URL=https://api.groq.com/openai/v1
# Together:      LLM_BASE_URL=https://api.together.xyz/v1
# DeepSeek:      LLM_BASE_URL=https://api.deepseek.com/v1
# OpenRouter:    LLM_BASE_URL=https://openrouter.ai/api/v1   (model slugs are provider/model, e.g. anthropic/claude-sonnet-4.6; see openrouter.ai/models)

# --- Provider keys: fill in the one(s) you use. api_key_for() picks by provider. ---
OPENAI_API_KEY=          # also used for Together / DeepSeek (OpenAI-compatible)
ANTHROPIC_API_KEY=       # sk-ant-...
OPENROUTER_API_KEY=      # sk-or-... (used when LLM_BASE_URL points at openrouter.ai)
GROQ_API_KEY=
GOOGLE_API_KEY=

# --- Eval harness (eval/ runs only; the episodes keep using LLM_* above) ---
# If unset, eval falls back to LLM_BASE_URL / LLM_AGENT_MODEL.
EVAL_LLM_BASE_URL=https://openrouter.ai/api/v1
EVAL_LLM_AGENT_MODEL=deepseek/deepseek-v4-flash
